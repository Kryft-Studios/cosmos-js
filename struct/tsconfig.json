{
  "compilerOptions": {
    "target": "ES2024",
    "module": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "nodenext",
    "declaration": true,            
    "emitDeclarationOnly": false,   
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@webgpu/types"]
  },
  "include": ["src"],
}
